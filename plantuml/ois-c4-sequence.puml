@startuml

!theme C4_OneIdentity from https://raw.githubusercontent.com/mpierson/oi-doc-generators/refs/heads/main/plantuml
!include https://raw.githubusercontent.com/mpierson/oi-doc-generators/refs/heads/main/plantuml/ois-sprites.puml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Sequence.puml

HIDE_STEREOTYPE()

UpdateSystemBoundaryStyle($bgColor="white")
UpdateRelStyle($COLOR_OI_BLACK, $COLOR_OI_LOBLOLLY)


AddComponentTag("SG_Admin", $bgColor=$COLOR_OI_LIGHT_BLUE, $fontColor=white,  $sprite="user,scale=0.6")
AddComponentTag("SG_User", $bgColor=$COLOR_OI_BROWN, $borderColor="$COLOR_OI_BLACK", $fontColor=white,  $sprite="user,scale=0.6")

AddComponentTag("PF_MicrosoftAD", $bgColor=$COLOR_OI_GREEN, $fontColor=white, $sprite="active_directory,scale=0.7,color=white")
AddComponentTag("PF_Linux", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="linux,scale=0.7,color=white")
AddComponentTag("PF_Windows", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="windows,scale=0.7,color=white")
AddComponentTag("PF_Cisco", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="cisco,scale=0.8,color=white")
AddComponentTag("PF_vSphere", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="vsphere,scale=0.8,color=white")
AddComponentTag("PF_IBM", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="IBM,scale=0.07,color=white")
AddComponentTag("PF_None", $bgColor=$COLOR_OI_ORANGE, $fontColor="white", $sprite="server_generic,scale=0.7,color=white")

AddComponentTag("OneIM_Approver", $bgColor=$COLOR_OI_MONTE_CARLO, $fontColor=$COLOR_OI_GRAY, $borderColor="$COLOR_OI_GRAY", $borderStyle="Solid")

AddComponentTag("OneIM", $bgColor=$COLOR_OI_BLUE, $fontColor="white", $borderColor="$COLOR_OI_GRAY", $sprite="ICON_OneIM,scale=0.6,color=white"  )
AddComponentTag("OneIM_TS_MicrosoftAD", $bgColor="#00A4EF", $fontColor=white, $sprite="active_directory,scale=0.7,color=white")
AddComponentTag("OneLogin", $bgColor=$COLOR_OI_BLUE, $fontColor="white", $borderColor="$COLOR_OI_GRAY", $sprite="ICON_OneIM,scale=0.6,color=white"  )
AddComponentTag("OneIM_HR", $bgColor="$COLOR_OI_BLUE_LAGOON", $fontColor=white, $sprite="active_directory,scale=0.7,color=white")
AddComponentTag("OneIM_TS_Generic", $bgColor="$COLOR_OI_BLUE_LAGOON", $fontColor=white )

AddComponentTag("ARS", $bgColor=$COLOR_OI_JACARTA, $fontColor="white" , $sprite="ICON_ARS,scale=0.4,color=white" )

@enduml
